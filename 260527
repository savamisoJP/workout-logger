  chest:     { label:"胸",   icon:"◈", color:"#FF6B6B", defaults:["ベンチプレス","インクラインプレス","ダンベルフライ","ディップス","ケーブルクロスオーバー"] },
  back:      { label:"背中", icon:"◉", color:"#4ECDC4", defaults:["デッドリフト","懸垂","ラットプルダウン","ベントオーバーロウ","シーテッドロウ"] },
  legs:      { label:"脚",   icon:"◆", color:"#FFE66D", defaults:["スクワット","レッグプレス","ルーマニアンデッドリフト","レッグカール","カーフレイズ"] },
  shoulders: { label:"肩",   icon:"◇", color:"#A8E6CF", defaults:["オーバーヘッドプレス","サイドレイズ","フロントレイズ","リアデルトフライ","アップライトロウ"] },
  arms:      { label:"腕",   icon:"◐", color:"#DDA0DD", defaults:["バーベルカール","ハンマーカール","トライセプスプッシュダウン","スカルクラッシャー","コンセントレーションカール"] },
  core:      { label:"体幹", icon:"○", color:"#F7DC6F", defaults:["プランク","クランチ","レッグレイズ","ロシアンツイスト","アブローラー"] },
};

// ═══════════════════════════════════════
// STATE
// ═══════════════════════════════════════
let logs = [];
// exOrder: { chest: ["ベンチプレス",..., "マシンフライ"], ... } — full ordered list per category
let exOrder = {};
let selCat = "chest";
let selEx  = CATS.chest.defaults[0];
let sets   = [{ weight:"", reps:"", unit:"kg" }];
let activeTab = "log";
let customTabCat = "chest";
let addModalFromCustom = false;
let addModalCat = "chest";
let renameTarget = null;
let deleteTarget = null;
let editSetTarget = null; // { logId }
let editSetData = [];     // working copy of sets for editing
let dragSrcIdx = null;
let saveTimer = null;

// allExercises: returns ordered list for a category
function allEx(cat) {
  if (exOrder[cat] && exOrder[cat].length) return exOrder[cat];
  return [...CATS[cat].defaults];
}

function isCustomEx(cat, name) {
  return !CATS[cat].defaults.includes(name);
}

// ═══════════════════════════════════════
// SUPABASE
// ═══════════════════════════════════════
async function dbGet(key) {
  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/workout_data?user_id=eq.${USER_ID}&data_key=eq.${key}&select=value`, {
      headers: { apikey:SUPABASE_KEY, Authorization:`Bearer ${SUPABASE_KEY}` }
    });
    const rows = await res.json();
    return rows.length ? JSON.parse(rows[0].value) : null;
  } catch { return null; }
}
async function dbSet(key, value) {
  try {
    await fetch(`${SUPABASE_URL}/rest/v1/workout_data`, {
      method:"POST",
      headers: { apikey:SUPABASE_KEY, Authorization:`Bearer ${SUPABASE_KEY}`, "Content-Type":"application/json", Prefer:"resolution=merge-duplicates" },
      body: JSON.stringify({ id:`${USER_ID}:${key}`, user_id:USER_ID, data_key:key, value:JSON.stringify(value), updated_at:new Date().toISOString() }),
    });
  } catch {}
}

function scheduleSave() {
  clearTimeout(saveTimer);
  setSaveInd("保存中...");
  saveTimer = setTimeout(async () => {
    await Promise.all([dbSet("logs", logs), dbSet("exOrder", exOrder)]);
    setSaveInd("✓ 保存済み");
    setTimeout(() => setSaveInd(""), 2000);
  }, 800);
}
function setSaveInd(m) { document.getElementById("save-indicator").textContent = m; }

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
async function init() {
  try {
    const [l, o, oldCustom] = await Promise.all([dbGet("logs"), dbGet("exOrder"), dbGet("custom")]);
    if (l) logs = l;
    if (o) exOrder = o;

    // migrate old "custom" key -> exOrder
    if (oldCustom && typeof oldCustom === "object") {
      for (const cat of Object.keys(CATS)) {
        const customs = oldCustom[cat] || [];
        if (!exOrder[cat]) exOrder[cat] = [...CATS[cat].defaults];
        for (const name of customs) {
          if (!exOrder[cat].includes(name)) exOrder[cat].push(name);
        }
      }
    }

    // ensure all defaults exist
    for (const cat of Object.keys(CATS)) {
      if (!exOrder[cat]) exOrder[cat] = [...CATS[cat].defaults];
      else {
        for (const d of CATS[cat].defaults) {
          if (!exOrder[cat].includes(d)) exOrder[cat].push(d);
        }
      }
    }
  } catch(e) { console.error(e); }
  document.getElementById("loading").style.display = "none";
  renderAll();
}

// ═══════════════════════════════════════
// RENDER
// ═══════════════════════════════════════
function renderAll() {
  renderCatGrid();
  renderExList();
  renderSets();
  renderHistory();
  renderStats();
  renderCustomTab();
  renderCustomCatTabs();
  updateVolume();
  updateCustomBadge();
  updateAddExBtn();
}

function renderCatGrid() {
  document.getElementById("cat-grid").innerHTML = Object.entries(CATS).map(([key,cat]) => {
    const customCount = allEx(key).filter(e => isCustomEx(key,e)).length;
    const on = key===selCat;
    return `<button class="cat-btn" onclick="selectCat('${key}')"
      style="background:${on?cat.color+"20":"#111"};border-color:${on?cat.color:"#222"};color:${on?cat.color:"#444"}">
      <div class="cat-icon">${cat.icon}</div>${cat.label}
      ${customCount>0?`<span class="cat-badge" style="background:${cat.color}">+${customCount}</span>`:""}
    </button>`;
  }).join("");
}

function renderExList() {
  const exes = allEx(selCat);
  const color = CATS[selCat].color;
  document.getElementById("ex-list").innerHTML = exes.map(ex => {
    const isMy = isCustomEx(selCat, ex);
    const on = ex===selEx;
    return `<button class="ex-btn${on?" active":""}" onclick="selectEx('${ex}')"
      style="border-color:${on?color:"#1A1A1A"}">
      <span class="ex-arrow" style="color:${color}">▶</span>
      <span style="flex:1">${ex}</span>
      ${isMy?`<span class="my-badge" style="color:${color};border-color:${color}">MY</span>`:""}
    </button>`;
  }).join("");
}

function renderSets() {
  document.getElementById("sets-container").innerHTML = sets.map((set,i) => `
    <div class="set-row">
      <div class="set-num">${String(i+1).padStart(2,"0")}</div>
      <div class="set-field">
        <input class="set-input" type="number" placeholder="0.0" value="${set.weight}"
          oninput="sets[${i}].weight=this.value">
      </div>
      <div class="set-field">
        <input class="set-input" type="number" placeholder="0" value="${set.reps}"
          oninput="sets[${i}].reps=this.value">
      </div>
      <div class="unit-toggle">
        <button class="unit-toggle-btn${set.unit==="kg"?" active":""}" onclick="setUnit(${i},'kg')">kg</button>
        <button class="unit-toggle-btn${set.unit==="lbs"?" active":""}" onclick="setUnit(${i},'lbs')">lbs</button>
      </div>
      ${sets.length>1?`<button class="set-del" onclick="removeSet(${i})">×</button>`:""}
    </div>`).join("");
}

function renderHistory() {
  const grouped = groupByDate(logs);
  const el = document.getElementById("history-list");
  if (!Object.keys(grouped).length) { el.innerHTML=`<div class="empty">NO RECORDS YET</div>`; return; }
  el.innerHTML = Object.entries(grouped).map(([date,dayLogs]) => `
    <div style="margin-bottom:24px">
      <div class="day-label">${date}</div>
      ${dayLogs.map(log => {
        const cat = CATS[log.category] || Object.values(CATS)[0];
        const maxW = Math.max(...log.sets.map(s=>parseFloat(s.weight)||0));
        const totR = log.sets.reduce((s,set)=>s+(parseInt(set.reps)||0),0);
        const hasLbs = log.sets.some(s=>s.unit==="lbs");
        const maxDisp = hasLbs ? (maxW*KG_TO_LBS).toFixed(1)+"lbs" : maxW.toFixed(1)+"kg";
        return `<div class="log-card">
          <div class="log-card-head" onclick="toggleLog('${log.id}')">
            <span class="log-cat-icon" style="color:${cat.color}">${cat.icon}</span>
            <div style="flex:1">
              <div class="log-name">${log.exercise}
                ${isCustomEx(log.category,log.exercise)?`<span class="my-badge" style="color:${cat.color};border-color:${cat.color}">MY</span>`:""}
              </div>
              <div class="log-meta">${log.sets.length}SET · MAX ${maxDisp} · ${totR}reps</div>
            </div>
            <span class="log-toggle" id="toggle-${log.id}">▼</span>
          </div>
          <div class="log-detail" id="detail-${log.id}">
            ${log.sets.map((set,i)=>{
              const dw = set.displayWeight || fmtW(set.weight, set.unit||"kg");
              const du = set.unit||"kg";
              const vol = (parseFloat(set.weight)*(parseInt(set.reps)||0)).toFixed(0);
              return `<div class="log-set-row">
                <span style="color:#333">SET ${i+1}</span>
                <span style="color:${cat.color}">${dw}${du}</span>
                <span>×</span><span>${set.reps}rep</span>
                <span style="color:#333">vol:${vol}kg</span>
                <button class="log-edit-btn" onclick="openEditSet('${log.id}',event)">編集</button>
              </div>`;
            }).join("")}
            ${log.note?`<div class="log-note">"${log.note}"</div>`:""}
            <button class="log-del-btn" onclick="deleteLog('${log.id}')">削除</button>
          </div>
        </div>`;
      }).join("")}
    </div>`).join("");
}

function renderStats() {
  const grouped = groupByDate(logs);
  const totalVol = logs.reduce((s,l)=>s+l.sets.reduce((a,set)=>a+(parseFloat(set.weight)||0)*(parseInt(set.reps)||0),0),0);
  const exCount = {};
  logs.forEach(l => exCount[l.exercise]=(exCount[l.exercise]||0)+1);
  const topEx = Object.entries(exCount).sort((a,b)=>b[1]-a[1])[0]?.[0]?.slice(0,8)||"—";
  document.getElementById("stat-grid").innerHTML = [
    { label:"総記録数",    value:logs.length+"件" },
    { label:"総ボリューム", value:totalVol>=1000?(totalVol/1000).toFixed(1)+"t":totalVol.toFixed(0)+"kg" },
    { label:"最多種目",    value:topEx },
    { label:"記録日数",    value:Object.keys(grouped).length+"日" },
  ].map(({label,value})=>`<div class="stat-card"><div class="stat-label">${label}</div><div class="stat-value">${value}</div></div>`).join("");

  const maxByEx = {};
  logs.forEach(l => {
    const mx = l.sets.reduce((m,s)=>parseFloat(s.weight)>parseFloat(m.weight||0)?s:m,{});
    if (!maxByEx[l.exercise]||parseFloat(mx.weight)>parseFloat(maxByEx[l.exercise].weight))
      maxByEx[l.exercise]={...mx,date:l.date,category:l.category};
  });
  const prEl = document.getElementById("pr-list");
  if (!Object.keys(maxByEx).length) { prEl.innerHTML=`<div class="empty" style="padding:40px 0">NO DATA</div>`; return; }
  prEl.innerHTML = Object.entries(maxByEx).map(([ex,data])=>{
    const cat = CATS[data.category]||Object.values(CATS)[0];
    const dispW = data.unit==="lbs"?(parseFloat(data.weight)*KG_TO_LBS).toFixed(1)+"lbs":parseFloat(data.weight).toFixed(1)+"kg";
    return `<div class="pr-row">
      <span style="color:${cat.color};font-size:16px;margin-right:12px">${cat.icon}</span>
      <div class="pr-info"><div class="pr-name">${ex}</div><div class="pr-date">${new Date(data.date).toLocaleDateString("ja-JP")} · ${data.reps}rep</div></div>
      <div class="pr-weight" style="color:${cat.color}">${dispW}</div>
    </div>`;
  }).join("");
}

function renderCustomTab() {
  const list = allEx(customTabCat);
  const color = CATS[customTabCat].color;
  const el = document.getElementById("custom-list");
  el.innerHTML = `<div style="font-size:10px;color:#333;letter-spacing:2px;margin-bottom:10px">☰ ドラッグで並び替え（デフォルト・カスタム両方）</div>` +
    list.map((ex,i) => {
      const isMy = isCustomEx(customTabCat, ex);
      return `<div class="custom-item" draggable="true"
        ondragstart="dragSrcIdx=${i}"
        ondragenter="handleDragEnter(event,${i})"
        ondragend="handleDragEnd()"
        ondragover="event.preventDefault()">
        <span class="drag-handle">⋮⋮</span>
        ${!isMy?`<span class="default-tag">DEFAULT</span>`:""}
        <span class="custom-name">${ex}</span>
        <button class="custom-action-btn" style="border:1px solid ${color};color:${color}"
          onclick="openRenameModal('${customTabCat}','${ex}')">名称変更</button>
        ${isMy?`<button class="custom-del-btn" onclick="openDeleteModal('${customTabCat}','${ex}')">×</button>`:`<div style="width:30px"></div>`}
      </div>`;
    }).join("");
}

function renderCustomCatTabs() {
  document.getElementById("custom-cat-tabs").innerHTML = Object.entries(CATS).map(([key,cat])=>{
    const customCnt = allEx(key).filter(e=>isCustomEx(key,e)).length;
    const on = key===customTabCat;
    return `<button class="cat-tab-btn" onclick="setCustomTabCat('${key}')"
      style="background:${on?cat.color+"20":"#0D0D0D"};border-color:${on?cat.color:"#1A1A1A"};color:${on?cat.color:"#444"}">
      ${cat.label}${customCnt>0?` (+${customCnt})`:""}
    </button>`;
  }).join("");
}

function updateVolume() {
  const v = logs.reduce((s,l)=>s+l.sets.reduce((a,set)=>a+(parseFloat(set.weight)||0)*(parseInt(set.reps)||0),0),0);
  document.getElementById("vol-value").textContent = v>=1000?`${(v/1000).toFixed(1)}t`:`${v.toFixed(0)}kg`;
}
function updateCustomBadge() {
  const cnt = Object.keys(CATS).reduce((s,k)=>s+allEx(k).filter(e=>isCustomEx(k,e)).length,0);
  const badge = document.getElementById("custom-badge");
  badge.style.display = cnt>0?"inline":"none";
  badge.textContent = cnt;
}
function updateAddExBtn() {
  const btn = document.getElementById("add-ex-btn");
  const color = CATS[selCat].color;
  btn.style.border=`1px solid ${color}`; btn.style.color=color;
}
function groupByDate(logs) {
  return logs.reduce((acc,log)=>{
    const d = new Date(log.date).toLocaleDateString("ja-JP",{year:"numeric",month:"long",day:"numeric",weekday:"short"});
    (acc[d]=acc[d]||[]).push(log); return acc;
  },{});
}

// ═══════════════════════════════════════
// ACTIONS — LOG TAB
// ═══════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll(".tab-btn").forEach(b=>b.classList.toggle("active",b.dataset.tab===tab));
  document.querySelectorAll(".screen").forEach(s=>s.classList.toggle("active",s.id==="tab-"+tab));
  activeTab = tab;
}
function selectCat(cat) {
  selCat=cat; selEx=allEx(cat)[0];
  renderCatGrid(); renderExList(); updateAddExBtn();
}
function selectEx(ex) { selEx=ex; renderExList(); }
function addSet() {
  const lastUnit = sets.length ? sets[sets.length-1].unit : "kg";
  sets.push({weight:"",reps:"",unit:lastUnit}); renderSets();
}
function removeSet(i) { sets.splice(i,1); renderSets(); }
function setUnit(i,unit) { sets[i].unit=unit; renderSets(); }

function saveWorkout() {
  const valid = sets.filter(s=>s.weight&&s.reps);
  if (!valid.length) { showToast("重量と回数を入力してください"); return; }
  logs.unshift({
    id: Date.now().toString(),
    date: new Date().toISOString(),
    category: selCat, exercise: selEx,
    sets: valid.map(s=>({
      weight: toKg(s.weight,s.unit).toFixed(2),
      displayWeight: s.weight,
      unit: s.unit,
      reps: s.reps,
    })),
    note: document.getElementById("note-input").value,
  });
  sets=[{weight:"",reps:"",unit:valid[valid.length-1]?.unit||"kg"}];
  document.getElementById("note-input").value="";
  scheduleSave(); renderAll(); showToast("✓ 保存しました");
}

// ═══════════════════════════════════════
// ACTIONS — HISTORY
// ═══════════════════════════════════════
function toggleLog(id) {
  const detail = document.getElementById("detail-"+id);
  const toggle = document.getElementById("toggle-"+id);
  const open = detail.classList.toggle("open");
  toggle.textContent = open?"▲":"▼";
}
function deleteLog(id) {
  logs=logs.filter(l=>l.id!==id); scheduleSave(); renderAll(); showToast("記録を削除しました");
}

// ── Edit Set Modal ──
function openEditSet(logId, e) {
  e.stopPropagation();
  const log = logs.find(l=>l.id===logId);
  if (!log) return;
  editSetTarget = logId;
  editSetData = log.sets.map(s=>({...s}));
  document.getElementById("editset-title").textContent = log.exercise;
  renderEditSetRows();
  document.getElementById("modal-editset").classList.add("open");
}

function renderEditSetRows() {
  document.getElementById("editset-rows").innerHTML = editSetData.map((set,i)=>{
    const dw = set.editWeight !== undefined
      ? set.editWeight
      : (set.displayWeight || fmtW(set.weight, set.unit||"kg"));
    const unit = set.unit || "kg";
    return `<div class="edit-set-row">
      <div class="edit-set-row-top">
        <div class="edit-set-num">SET ${i+1}</div>
        <input class="edit-set-input" type="number" value="${dw}" oninput="editSetData[${i}].editWeight=this.value" placeholder="重量">
        <input class="edit-set-input" type="number" value="${set.reps}" oninput="editSetData[${i}].reps=this.value" placeholder="回数" style="max-width:64px">
      </div>
      <div class="edit-unit-toggle">
        <button class="edit-unit-btn${unit==="kg"?" active":""}" onclick="editSetUnitOnly(${i},'kg')">kg</button>
        <button class="edit-unit-btn${unit==="lbs"?" active":""}" onclick="editSetUnitOnly(${i},'lbs')">lbs</button>
      </div>
    </div>`;
  }).join("");
}

function editSetUnitOnly(i, unit) {
  // just change the unit label, keep the number as-is
  editSetData[i].unit = unit;
  renderEditSetRows();
}

function confirmEditSet() {
  const idx = logs.findIndex(l=>l.id===editSetTarget);
  if (idx===-1) return;
  logs[idx].sets = editSetData.map(s=>{
    const inputW = s.editWeight !== undefined ? s.editWeight : (s.displayWeight || fmtW(s.weight, s.unit||"kg"));
    const unit = s.unit||"kg";
    return {
      weight: toKg(inputW, unit).toFixed(2),
      displayWeight: String(inputW),
      unit,
      reps: s.reps,
    };
  });
  closeModal("editset");
  scheduleSave(); renderAll(); showToast("✓ 記録を修正しました");
}

// ═══════════════════════════════════════
// ACTIONS — CUSTOM TAB / DRAG SORT
// ═══════════════════════════════════════
function setCustomTabCat(cat) { customTabCat=cat; renderCustomCatTabs(); renderCustomTab(); }
function goToLog(cat,ex) { selCat=cat; selEx=ex; switchTab("log"); renderCatGrid(); renderExList(); updateAddExBtn(); }

function handleDragEnter(e, toIdx) {
  e.preventDefault();
  if (dragSrcIdx===null||dragSrcIdx===toIdx) return;
  const list = allEx(customTabCat);
  const [moved] = list.splice(dragSrcIdx,1);
  list.splice(toIdx,0,moved);
  exOrder[customTabCat] = list;
  dragSrcIdx = toIdx;
  renderCustomTab();
}
function handleDragEnd() { dragSrcIdx=null; scheduleSave(); }

// ═══════════════════════════════════════
// MODALS
// ═══════════════════════════════════════
function openAddModal(fromCustom) {
  addModalFromCustom = !!fromCustom;
  addModalCat = fromCustom ? customTabCat : selCat;
  document.getElementById("add-name-input").value="";
  renderAddCatGrid();
  document.getElementById("modal-add").classList.add("open");
  setTimeout(()=>document.getElementById("add-name-input").focus(),100);
}
function renderAddCatGrid() {
  document.getElementById("add-cat-grid").innerHTML = Object.entries(CATS).map(([key,cat])=>{
    const on = key===addModalCat;
    return `<button class="modal-cat-btn" onclick="addModalCat='${key}';renderAddCatGrid()"
      style="background:${on?cat.color+"20":"#0D0D0D"};border-color:${on?cat.color:"#222"};color:${on?cat.color:"#444"}">
      <div style="font-size:14px;margin-bottom:2px">${cat.icon}</div>${cat.label}</button>`;
  }).join("");
}
function confirmAdd() {
  const name = document.getElementById("add-name-input").value.trim();
  if (!name) { showToast("種目名を入力してください"); return; }
  if (allEx(addModalCat).includes(name)) { showToast("すでに登録済みです"); return; }
  exOrder[addModalCat] = [...allEx(addModalCat), name];
  closeModal("add");
  selCat=addModalCat; selEx=name;
  scheduleSave(); renderAll(); showToast(`✓「${name}」を追加しました`);
  if (!addModalFromCustom) switchTab("log");
}

function openRenameModal(category, oldName) {
  renameTarget={category,oldName};
  document.getElementById("rename-old").textContent=`「${oldName}」`;
  document.getElementById("rename-input").value=oldName;
  document.getElementById("modal-rename").classList.add("open");
  setTimeout(()=>document.getElementById("rename-input").focus(),100);
}
function confirmRename() {
  const name = document.getElementById("rename-input").value.trim();
  if (!name) { showToast("種目名を入力してください"); return; }
  const {category,oldName} = renameTarget;
  if (name===oldName) { closeModal("rename"); return; }
  if (allEx(category).includes(name)) { showToast("同じ名前がすでにあります"); return; }
  exOrder[category] = allEx(category).map(e=>e===oldName?name:e);
  logs = logs.map(l=>l.category===category&&l.exercise===oldName?{...l,exercise:name}:l);
  if (selCat===category&&selEx===oldName) selEx=name;
  closeModal("rename"); scheduleSave(); renderAll(); showToast(`✓「${oldName}」→「${name}」`);
}

function openDeleteModal(category, name) {
  deleteTarget={category,name};
  document.getElementById("delete-name").textContent=`「${name}」`;
  document.getElementById("modal-delete").classList.add("open");
}
function confirmDelete() {
  const {category,name} = deleteTarget;
  exOrder[category] = allEx(category).filter(e=>e!==name);
  if (selCat===category&&selEx===name) selEx=allEx(category)[0];
  closeModal("delete"); scheduleSave(); renderAll(); showToast(`「${name}」を削除しました`);
}

function closeModal(id) { document.getElementById("modal-"+id).classList.remove("open"); }

// ═══════════════════════════════════════
// TIMER
// ═══════════════════════════════════════
let timerDuration = 90; // seconds
let timerRemaining = 90;
let timerRunning = false;
let timerInterval = null;
let timerOpen = false;

function toggleTimer() {
  timerOpen = !timerOpen;
  document.getElementById("timer-panel").classList.toggle("open", timerOpen);
}
function setTimerPreset(sec) {
  if (timerRunning) return;
  timerDuration = sec;
  timerRemaining = sec;
  document.querySelectorAll(".timer-preset-btn").forEach(b => {
    b.classList.toggle("active", parseInt(b.textContent.replace(":",""))*60+parseInt(b.textContent.split(":")[1]||0)===sec
      || (sec===60&&b.textContent==="1:00") || (sec===90&&b.textContent==="1:30")
      || (sec===120&&b.textContent==="2:00") || (sec===180&&b.textContent==="3:00"));
  });
  updateTimerDisplay();
}
function toggleTimerRun() {
  if (timerRunning) { pauseTimer(); } else { startTimer(); }
}
function startTimer() {
  if (timerRemaining<=0) timerRemaining=timerDuration;
  timerRunning=true;
  document.getElementById("timer-start-btn").textContent="一時停止";
  document.getElementById("timer-display").classList.remove("done");
  timerInterval = setInterval(()=>{
    timerRemaining--;
    updateTimerDisplay();
    if (timerRemaining<=0) {
      timerFinished();
    }
  },1000);
}
function pauseTimer() {
  timerRunning=false;
  clearInterval(timerInterval);
  document.getElementById("timer-start-btn").textContent="スタート";
}
function resetTimer() {
  pauseTimer();
  timerRemaining=timerDuration;
  document.getElementById("timer-display").classList.remove("done");
  updateTimerDisplay();
}
function timerFinished() {
  pauseTimer();
  document.getElementById("timer-display").classList.add("done");
  document.getElementById("timer-display").textContent="完了！";
  document.getElementById("timer-start-btn").textContent="スタート";
  // vibrate if supported
  if (navigator.vibrate) navigator.vibrate([300,100,300,100,500]);
  showToast("⏱ インターバル終了！");
  // auto-open panel
  if (!timerOpen) { timerOpen=true; document.getElementById("timer-panel").classList.add("open"); }
}
function updateTimerDisplay() {
  const m = Math.floor(timerRemaining/60);
  const s = timerRemaining%60;
  document.getElementById("timer-display").textContent=`${m}:${String(s).padStart(2,"0")}`;
}

// ═══════════════════════════════════════
// TOAST
// ═══════════════════════════════════════
let toastTimer;
function showToast(msg) {
  const el=document.getElementById("toast");
  el.textContent=msg; el.style.display="block";
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.style.display="none",2500);
}

// ═══════════════════════════════════════
// CLAUDE SUMMARY
// ═══════════════════════════════════════
function copySummaryForClaude() {
  const now = new Date();
  const summary = [];

  summary.push("=== WORKOUT LOGGER サマリー ===");
  summary.push(`生成日時: ${now.toLocaleDateString("ja-JP",{year:"numeric",month:"long",day:"numeric"})}`);
  summary.push("");

  // ── 直近4週間の頻度 ──
  const msPerWeek = 7*24*60*60*1000;
  const weeks = [0,1,2,3].map(w => {
    const end = new Date(now - w*msPerWeek);
    const start = new Date(now - (w+1)*msPerWeek);
    const days = new Set(
      logs.filter(l => { const d=new Date(l.date); return d>=start && d<end; })
          .map(l => new Date(l.date).toLocaleDateString("ja-JP"))
    );
    const exes = logs.filter(l => { const d=new Date(l.date); return d>=start && d<end; })
                     .map(l => l.exercise);
    return { label: w===0?"今週": w===1?"先週":`${w+1}週前`, days: days.size, exercises: [...new Set(exes)] };
  });

  summary.push("【直近4週間のトレーニング頻度】");
  weeks.forEach(w => {
    summary.push(`${w.label}: ${w.days}回 ${w.exercises.length>0?"("+w.exercises.slice(0,4).join("、")+(w.exercises.length>4?"他":"")+")" :""}`);
  });
  summary.push("");

  // ── 種目ごとPR ──
  const maxByEx = {};
  logs.forEach(l => {
    const mx = l.sets.reduce((m,s)=>parseFloat(s.weight)>parseFloat(m.weight||0)?s:m,{});
    if (!maxByEx[l.exercise]||parseFloat(mx.weight)>parseFloat(maxByEx[l.exercise].weight))
      maxByEx[l.exercise]={...mx, date:l.date, category:l.category};
  });

  summary.push("【種目別MAX重量（PR）】");
  Object.entries(maxByEx).forEach(([ex,data]) => {
    const unit = data.unit||"kg";
    const dispW = unit==="lbs"
      ? (parseFloat(data.weight)*KG_TO_LBS).toFixed(1)+"lbs"
      : parseFloat(data.weight).toFixed(1)+"kg";
    const cat = CATS[data.category]||Object.values(CATS)[0];
    summary.push(`${cat.label} / ${ex}: ${dispW} × ${data.reps}rep (${new Date(data.date).toLocaleDateString("ja-JP")})`);
  });
  summary.push("");

  // ── 直近8回分の記録（種目ごと最新） ──
  const recentByEx = {};
  [...logs].forEach(l => {
    if (!recentByEx[l.exercise]) recentByEx[l.exercise] = [];
    if (recentByEx[l.exercise].length < 3) recentByEx[l.exercise].push(l);
  });

  summary.push("【直近の記録（種目ごと最新3回）】");
  Object.entries(recentByEx).forEach(([ex, recs]) => {
    summary.push(`▼ ${ex}`);
    recs.forEach(r => {
      const setStr = r.sets.map(s => {
        const u = s.unit||"kg";
        const w = u==="lbs"?(parseFloat(s.weight)*KG_TO_LBS).toFixed(1)+"lbs":parseFloat(s.weight).toFixed(1)+"kg";
        return `${w}×${s.reps}`;
      }).join(" / ");
      summary.push(`  ${new Date(r.date).toLocaleDateString("ja-JP")}: ${setStr}`);
    });
  });
  summary.push("");

  // ── 先週のボリューム ──
  const lastWeekStart = new Date(now - msPerWeek);
  const lastWeekVol = logs
    .filter(l => new Date(l.date) >= lastWeekStart)
    .reduce((s,l)=>s+l.sets.reduce((a,set)=>a+(parseFloat(set.weight)||0)*(parseInt(set.reps)||0),0),0);
  summary.push(`【直近7日間の総ボリューム】 ${lastWeekVol>=1000?(lastWeekVol/1000).toFixed(1)+"t":lastWeekVol.toFixed(0)+"kg"}`);
  summary.push("");
  summary.push("=== 以上 ===");

  const text = summary.join("
");
  navigator.clipboard.writeText(text).then(() => {
    showToast("✓ クリップボードにコピーしました");
  }).catch(() => {
    // fallback for older browsers
    const ta = document.createElement("textarea");
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand("copy");
    document.body.removeChild(ta);
    showToast("✓ コピーしました");
  });
}

