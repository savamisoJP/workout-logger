<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="WORKOUT">
<title>WORKOUT LOGGER</title>
<style>
* { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }
body { background:#0A0A0A; color:#EAEAEA; font-family:'Courier New',monospace; min-height:100vh; min-height:-webkit-fill-available; }
input,textarea,button,select { font-family:'Courier New',monospace; }
input[type=number]::-webkit-inner-spin-button { -webkit-appearance:none; }
button { cursor:pointer; }
.screen { display:none; } .screen.active { display:block; }

/* Header */
#header { padding:52px 20px 0; border-bottom:1px solid #1E1E1E; position:sticky; top:0; background:#0A0A0A; z-index:10; }
#header-top { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:16px; }
#header-sub { font-size:10px; letter-spacing:4px; color:#555; margin-bottom:4px; }
#header-title { font-size:28px; font-weight:900; letter-spacing:-1px; line-height:1; }
#header-title span { color:#FF6B6B; margin-left:4px; }
#vol-label { font-size:10px; color:#444; letter-spacing:2px; }
#vol-value { font-size:18px; font-weight:700; color:#FF6B6B; text-align:right; }
#save-indicator { font-size:9px; color:#555; letter-spacing:1px; text-align:right; min-height:14px; }
#tabs { display:flex; }
.tab-btn { flex:1; padding:10px 0; background:none; border:none; border-bottom:2px solid transparent; color:#444; font-size:10px; letter-spacing:2px; transition:color 0.2s; }
.tab-btn.active { border-bottom-color:#FF6B6B; color:#FF6B6B; }
.tab-badge { margin-left:4px; background:#FF6B6B; color:#0A0A0A; border-radius:10px; padding:0 5px; font-size:9px; }

/* Content */
#content { padding:20px; padding-bottom:60px; }
.sec-label { font-size:10px; letter-spacing:3px; color:#555; margin-bottom:10px; }

/* Category grid */
.cat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:20px; }
.cat-btn { padding:10px 8px; position:relative; background:#111; border:1px solid #222; color:#444; font-size:12px; border-radius:2px; transition:all 0.15s; }
.cat-icon { font-size:16px; margin-bottom:2px; }
.cat-badge { position:absolute; top:4px; right:4px; border-radius:8px; padding:0 4px; font-size:8px; font-weight:bold; color:#0A0A0A; }

/* Exercise list */
.ex-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.ex-list { display:flex; flex-direction:column; gap:6px; margin-bottom:20px; }
.ex-btn { padding:12px 14px; background:#0D0D0D; border:1px solid #1A1A1A; color:#555; font-size:13px; text-align:left; border-radius:2px; display:flex; align-items:center; gap:10px; transition:all 0.15s; width:100%; }
.ex-btn.active { background:#1A1A1A; color:#EAEAEA; }
.ex-arrow { display:none; } .ex-btn.active .ex-arrow { display:inline; }
.my-badge { font-size:8px; letter-spacing:1px; border:1px solid; padding:1px 5px; border-radius:2px; opacity:0.7; margin-left:auto; flex-shrink:0; }

/* Sets */
.set-row { display:flex; align-items:center; gap:6px; margin-bottom:8px; }
.set-num { font-size:12px; color:#333; width:22px; text-align:center; flex-shrink:0; }
.set-field { flex:1; position:relative; }
.set-input { width:100%; padding:10px 8px; background:#111; border:1px solid #222; color:#EAEAEA; font-size:14px; border-radius:2px; outline:none; text-align:center; }
.set-del { width:32px; height:38px; background:none; border:1px solid #222; color:#444; font-size:14px; flex-shrink:0; border-radius:2px; }
.unit-toggle { display:flex; border:1px solid #2A2A2A; border-radius:2px; overflow:hidden; flex-shrink:0; }
.unit-toggle-btn { padding:0 7px; height:38px; background:none; border:none; color:#444; font-size:10px; letter-spacing:1px; transition:all 0.15s; }
.unit-toggle-btn.active { background:#2A2A2A; color:#EAEAEA; }
#add-set-btn { width:100%; margin-top:8px; padding:10px; background:none; border:1px dashed #2A2A2A; color:#444; font-size:11px; letter-spacing:2px; border-radius:2px; }
#note-input { width:100%; padding:12px; background:#111; border:1px solid #222; color:#888; font-size:12px; resize:none; border-radius:2px; outline:none; margin-bottom:20px; }
#save-btn { width:100%; padding:16px; background:#FF6B6B; border:none; color:#0A0A0A; font-size:13px; font-weight:900; letter-spacing:4px; border-radius:2px; }

/* Timer */
#timer-fab { position:fixed; bottom:24px; right:20px; width:56px; height:56px; background:#FF6B6B; border:none; border-radius:50%; font-size:22px; color:#0A0A0A; z-index:50; box-shadow:0 4px 16px rgba(255,107,107,0.4); display:flex; align-items:center; justify-content:center; }
#timer-panel { position:fixed; bottom:0; left:0; right:0; background:#111; border-top:1px solid #2A2A2A; padding:20px; z-index:60; transform:translateY(100%); transition:transform 0.3s; }
#timer-panel.open { transform:translateY(0); }
#timer-display { font-size:52px; font-weight:900; text-align:center; letter-spacing:4px; color:#FF6B6B; margin:12px 0; }
#timer-display.done { color:#4ECDC4; }
.timer-presets { display:flex; gap:8px; justify-content:center; margin-bottom:16px; }
.timer-preset-btn { padding:6px 14px; background:none; border:1px solid #2A2A2A; color:#555; font-size:11px; letter-spacing:1px; border-radius:2px; }
.timer-preset-btn.active { border-color:#FF6B6B; color:#FF6B6B; }
.timer-controls { display:flex; gap:10px; }
.timer-ctrl-btn { flex:1; padding:12px; background:none; border:1px solid #2A2A2A; color:#EAEAEA; font-size:12px; letter-spacing:2px; border-radius:2px; }
.timer-ctrl-btn.primary { background:#FF6B6B; border-color:#FF6B6B; color:#0A0A0A; font-weight:900; }
.timer-close { position:absolute; top:16px; right:16px; background:none; border:none; color:#444; font-size:18px; }

/* History */
.day-label { font-size:10px; letter-spacing:3px; color:#444; margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid #1A1A1A; }
.log-card { background:#0D0D0D; border:1px solid #1A1A1A; margin-bottom:8px; border-radius:2px; overflow:hidden; }
.log-card-head { padding:14px; display:flex; align-items:center; gap:12px; }
.log-cat-icon { font-size:18px; }
.log-name { font-size:13px; margin-bottom:2px; display:flex; align-items:center; gap:6px; }
.log-meta { font-size:10px; color:#444; letter-spacing:1px; }
.log-toggle { color:#333; font-size:10px; margin-left:auto; flex-shrink:0; }
.log-detail { border-top:1px solid #1A1A1A; padding:14px; display:none; }
.log-detail.open { display:block; }
.log-set-row { display:flex; gap:12px; margin-bottom:6px; font-size:12px; color:#888; align-items:center; }
.log-edit-btn { margin-left:auto; padding:2px 8px; background:none; border:1px solid #2A2A2A; color:#555; font-size:9px; letter-spacing:1px; border-radius:2px; flex-shrink:0; }
.log-note { margin-top:8px; font-size:11px; color:#444; font-style:italic; }
.log-del-btn { margin-top:12px; padding:6px 12px; background:none; border:1px solid #2A2A2A; color:#444; font-size:10px; letter-spacing:2px; border-radius:2px; }

/* Stats */
.stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:20px; }
.stat-card { background:#0D0D0D; border:1px solid #1A1A1A; padding:14px; border-radius:2px; }
.stat-label { font-size:9px; color:#444; letter-spacing:2px; margin-bottom:6px; }
.stat-value { font-size:18px; font-weight:700; color:#FF6B6B; }
.pr-row { display:flex; align-items:center; padding:12px 14px; margin-bottom:6px; background:#0D0D0D; border:1px solid #1A1A1A; border-radius:2px; }
.pr-info { flex:1; }
.pr-name { font-size:12px; margin-bottom:2px; }
.pr-date { font-size:10px; color:#444; }
.pr-weight { font-size:18px; font-weight:700; }

/* Custom / Exercise order tab */
.custom-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
.cat-tab-row { display:flex; gap:6px; margin-bottom:16px; overflow-x:auto; padding-bottom:4px; }
.cat-tab-btn { padding:6px 12px; flex-shrink:0; background:#0D0D0D; border:1px solid #1A1A1A; color:#444; font-size:11px; border-radius:2px; }
.custom-item { display:flex; align-items:center; padding:12px 14px; margin-bottom:6px; background:#0D0D0D; border:1px solid #1A1A1A; border-radius:2px; user-select:none; }
.drag-handle { color:#333; font-size:14px; margin-right:12px; cursor:grab; touch-action:none; }
.custom-name { flex:1; font-size:13px; }
.custom-action-btn { padding:4px 8px; background:none; font-size:9px; letter-spacing:1px; border-radius:2px; margin-right:4px; }
.custom-del-btn { padding:4px 8px; background:none; border:1px solid #2A2A2A; color:#444; font-size:12px; border-radius:2px; }
.default-tag { font-size:8px; color:#333; border:1px solid #222; padding:1px 4px; border-radius:2px; margin-right:6px; }

/* Shared buttons */
.add-btn { padding:6px 14px; background:#FF6B6B; border:none; color:#0A0A0A; font-size:10px; font-weight:700; letter-spacing:2px; border-radius:2px; }
.outline-btn { padding:4px 10px; background:none; font-size:10px; letter-spacing:2px; border-radius:2px; }

/* Modal */
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:100; display:none; }
.modal-overlay.open { display:flex; }
.modal-bottom { width:100%; background:#111; border-top:1px solid #2A2A2A; padding:24px 20px 40px; margin-top:auto; }
.modal-center { width:100%; max-width:340px; background:#111; border:1px solid #2A2A2A; padding:24px; border-radius:2px; margin:auto; }
.modal-title { font-size:11px; letter-spacing:3px; color:#555; margin-bottom:18px; }
.modal-sub { font-size:11px; color:#333; margin-bottom:12px; }
.field-label { font-size:10px; color:#444; letter-spacing:2px; margin-bottom:8px; margin-top:12px; }
.modal-input { width:100%; padding:11px 12px; background:#0D0D0D; border:1px solid #222; color:#EAEAEA; font-size:13px; border-radius:2px; outline:none; }
.modal-btn-row { display:flex; gap:10px; margin-top:16px; }
.modal-cancel { flex:1; padding:14px; background:none; border:1px solid #2A2A2A; color:#444; font-size:12px; letter-spacing:2px; border-radius:2px; }
.modal-confirm { flex:2; padding:14px; background:#FF6B6B; border:none; color:#0A0A0A; font-size:12px; font-weight:900; letter-spacing:3px; border-radius:2px; }
.modal-danger { flex:1; padding:12px; background:#2A1010; border:1px solid #FF4444; color:#FF4444; font-size:11px; font-weight:700; border-radius:2px; }
.modal-cat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:8px; margin-bottom:4px; }
.modal-cat-btn { padding:10px 8px; background:#0D0D0D; border:1px solid #222; color:#444; font-size:12px; border-radius:2px; }
.modal-unit-row { display:flex; gap:8px; margin-top:8px; }
.modal-unit-btn { flex:1; padding:10px; background:#0D0D0D; border:1px solid #222; color:#444; font-size:12px; border-radius:2px; }
.edit-set-row { display:flex; flex-direction:column; gap:6px; padding:10px 0; border-bottom:1px solid #1A1A1A; }
.edit-set-row-top { display:flex; gap:8px; align-items:center; }
.edit-set-num { font-size:11px; color:#444; width:32px; flex-shrink:0; }
.edit-set-input { flex:1; padding:8px; background:#0D0D0D; border:1px solid #222; color:#EAEAEA; font-size:13px; border-radius:2px; outline:none; text-align:center; }
.edit-unit-toggle { display:flex; border:1px solid #2A2A2A; border-radius:2px; overflow:hidden; margin-left:40px; }
.edit-unit-btn { flex:1; padding:7px 14px; background:none; border:none; color:#444; font-size:11px; letter-spacing:1px; }
.edit-unit-btn.active { background:#2A2A2A; color:#EAEAEA; }

/* Toast */
#toast { position:fixed; bottom:100px; left:50%; transform:translateX(-50%); background:#FF6B6B; color:#0A0A0A; padding:10px 24px; font-size:12px; font-weight:700; letter-spacing:2px; border-radius:2px; z-index:999; white-space:nowrap; display:none; }

/* Misc */
.empty { text-align:center; color:#333; padding:60px 0; font-size:13px; letter-spacing:2px; }
.empty-sub { font-size:11px; color:#2A2A2A; margin-top:6px; }
#loading { position:fixed; inset:0; background:#0A0A0A; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:200; }
#loading .l1 { font-size:10px; letter-spacing:4px; color:#555; margin-bottom:16px; }
#loading .l2 { font-size:11px; letter-spacing:3px; color:#333; }
</style>
</head>
<body>

<div id="loading">
  <div class="l1">WORKOUT LOGGER</div>
  <div class="l2">データを読み込み中...</div>
</div>

<div id="header">
  <div id="header-top">
    <div>
      <div id="header-sub">WORKOUT</div>
      <div id="header-title">LOGGER<span>_</span></div>
    </div>
    <div>
      <div id="vol-label">TOTAL VOLUME</div>
      <div id="vol-value">0kg</div>
      <div id="save-indicator"></div>
    </div>
  </div>
  <div id="tabs">
    <button class="tab-btn active" data-tab="log">記録</button>
    <button class="tab-btn" data-tab="history">履歴</button>
    <button class="tab-btn" data-tab="stats">分析</button>
    <button class="tab-btn" data-tab="custom">種目<span id="custom-badge" class="tab-badge" style="display:none"></span></button>
  </div>
</div>

<div id="content">
  <!-- LOG -->
  <div id="tab-log" class="screen active">
    <div class="sec-label">BODY PART</div>
    <div class="cat-grid" id="cat-grid"></div>
    <div class="ex-header">
      <div class="sec-label" style="margin-bottom:0">EXERCISE</div>
      <button class="outline-btn" id="add-ex-btn" onclick="openAddModal()">+ 種目追加</button>
    </div>
    <div class="ex-list" id="ex-list"></div>
    <div class="sec-label">SETS</div>
    <div id="sets-container"></div>
    <button id="add-set-btn" onclick="addSet()">+ SET追加</button>
    <textarea id="note-input" rows="2" placeholder="メモ（任意）" style="margin-top:16px"></textarea>
    <button id="save-btn" onclick="saveWorkout()">SAVE WORKOUT</button>
  </div>

  <!-- HISTORY -->
  <div id="tab-history" class="screen">
    <div id="history-list"></div>
  </div>

  <!-- STATS -->
  <div id="tab-stats" class="screen">
    <div class="sec-label">OVERVIEW</div>
    <div class="stat-grid" id="stat-grid"></div>
    <div class="sec-label">MAX WEIGHT PR</div>
    <div id="pr-list"></div>
    <div style="margin-top:28px;padding-top:20px;border-top:1px solid #1A1A1A">
      <div class="sec-label">CLAUDE連携</div>
      <div style="font-size:11px;color:#444;margin-bottom:12px;line-height:1.6">
        ボタンをタップするとトレーニングサマリーをコピーします。<br>Claudeのチャットに貼り付けてメニュー相談に使えます。
      </div>
      <button onclick="copySummaryForClaude()" style="width:100%;padding:14px;background:none;border:1px solid #FF6B6B;color:#FF6B6B;font-size:12px;font-weight:700;letter-spacing:3px;border-radius:2px;font-family:'Courier New',monospace">
        📋 Claudeにサマリーをコピー
      </button>
    </div>
  </div>

  <!-- CUSTOM / ORDER -->
  <div id="tab-custom" class="screen">
    <div class="custom-top">
      <div class="sec-label" style="margin-bottom:0">EXERCISE ORDER</div>
      <button class="add-btn" onclick="openAddModal(true)">+ 新規追加</button>
    </div>
    <div class="cat-tab-row" id="custom-cat-tabs"></div>
    <div id="custom-list"></div>
  </div>
</div>

<!-- Timer FAB -->
<button id="timer-fab" onclick="toggleTimer()">⏱</button>

<!-- Timer Panel -->
<div id="timer-panel">
  <button class="timer-close" onclick="toggleTimer()">×</button>
  <div style="font-size:10px;letter-spacing:3px;color:#555;margin-bottom:4px">INTERVAL TIMER</div>
  <div id="timer-display">1:30</div>
  <div class="timer-presets">
    <button class="timer-preset-btn" onclick="setTimerPreset(60)">1:00</button>
    <button class="timer-preset-btn active" onclick="setTimerPreset(90)">1:30</button>
    <button class="timer-preset-btn" onclick="setTimerPreset(120)">2:00</button>
    <button class="timer-preset-btn" onclick="setTimerPreset(180)">3:00</button>
  </div>
  <div class="timer-controls">
    <button class="timer-ctrl-btn" onclick="resetTimer()">リセット</button>
    <button class="timer-ctrl-btn primary" id="timer-start-btn" onclick="toggleTimerRun()">スタート</button>
  </div>
</div>

<!-- Toast -->
<div id="toast"></div>

<!-- Add Exercise Modal -->
<div class="modal-overlay" id="modal-add" onclick="if(event.target===this)closeModal('add')">
  <div class="modal-bottom">
    <div class="modal-title">NEW EXERCISE</div>
    <div class="field-label" style="margin-top:0">種目名</div>
    <input class="modal-input" id="add-name-input" placeholder="例：チェストプレスマシン" onkeydown="if(event.key==='Enter')confirmAdd()">
    <div class="field-label">部位</div>
    <div class="modal-cat-grid" id="add-cat-grid"></div>
    <div class="modal-btn-row">
      <button class="modal-cancel" onclick="closeModal('add')">キャンセル</button>
      <button class="modal-confirm" onclick="confirmAdd()">追加する</button>
    </div>
  </div>
</div>

<!-- Rename Modal -->
<div class="modal-overlay" id="modal-rename" onclick="if(event.target===this)closeModal('rename')">
  <div class="modal-bottom">
    <div class="modal-title">RENAME EXERCISE</div>
    <div class="modal-sub" id="rename-old"></div>
    <div class="field-label" style="margin-top:0">新しい名前</div>
    <input class="modal-input" id="rename-input" onkeydown="if(event.key==='Enter')confirmRename()">
    <div class="modal-btn-row">
      <button class="modal-cancel" onclick="closeModal('rename')">キャンセル</button>
      <button class="modal-confirm" onclick="confirmRename()">変更する</button>
    </div>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal-overlay" id="modal-delete" style="align-items:center;justify-content:center">
  <div class="modal-center">
    <div class="modal-title">CONFIRM DELETE</div>
    <div class="modal-sub" id="delete-name"></div>
    <div style="font-size:11px;color:#555;margin-bottom:20px">を削除しますか？記録は残ります。</div>
    <div class="modal-btn-row">
      <button class="modal-cancel" onclick="closeModal('delete')">キャンセル</button>
      <button class="modal-danger" onclick="confirmDelete()">削除</button>
    </div>
  </div>
</div>

<!-- Edit Set Modal -->
<div class="modal-overlay" id="modal-editset" onclick="if(event.target===this)closeModal('editset')" style="align-items:center;justify-content:center">
  <div class="modal-center" style="max-height:80vh;overflow-y:auto">
    <div class="modal-title">EDIT RECORD</div>
    <div class="modal-sub" id="editset-title"></div>
    <div id="editset-rows"></div>
    <div class="modal-btn-row">
      <button class="modal-cancel" onclick="closeModal('editset')">キャンセル</button>
      <button class="modal-confirm" onclick="confirmEditSet()">保存する</button>
    </div>
  </div>
</div>

